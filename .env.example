# Meta WhatsApp Cloud API credentials
# Copy to .env.local for dev, or set in Vercel project env for prod.

# Token you choose; paste the same value into Meta's webhook config "Verify token" field.
WA_VERIFY_TOKEN=replace-with-a-long-random-string

# App secret from Meta App Dashboard -> Settings -> Basic. Used to validate x-hub-signature-256.
WA_APP_SECRET=replace-with-meta-app-secret

# Phone number ID from WhatsApp -> API Setup. Numeric, ~15 digits.
WA_PHONE_NUMBER_ID=

# Permanent System User access token (preferred) or temp 24h token from API Setup.
WA_ACCESS_TOKEN=

# --- mailto IMAP fallback (component #6) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-address@gmail.com
# Gmail App Password (16 chars, no spaces). NOT your normal Gmail password.
# Create one at: https://myaccount.google.com/apppasswords
IMAP_APP_PASSWORD=
# Gmail label to read from. Filter inbound mail into this label (see README).
IMAP_LABEL=connecting-dots
# Poll cadence in seconds. 300s = 5min, the default hot-spare cadence.
IMAP_POLL_INTERVAL_S=300

# --- LinkedIn data-export ZIP watcher (component #7) ---
# Drop monthly LinkedIn export ZIPs into this folder; the watcher unpacks
# them, parses Saved Articles + Reactions, and feeds them to the dispatcher.
LINKEDIN_INBOX_DIR=data/linkedin-inbox
# Poll cadence in seconds. 60s is plenty for a monthly drop.
LINKEDIN_POLL_INTERVAL_S=60

# --- Upstash Redis Stream (cross-language bridge: TS webhook -> Python consumer) ---
# Create a free-tier Redis DB at https://console.upstash.com/redis
# Copy the REST URL + REST token (NOT the redis:// connection string).
# Set the same values in Vercel project env (Production + Preview) and in local .env.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- logging ---
LOG_LEVEL=INFO
